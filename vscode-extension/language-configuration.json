{
  "comments": {
    "lineComment": "@//"
  },
  "brackets": [
    ["{", "}"],
    ["(", ")"],
    ["[", "]"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" },
    { "open": "${", "close": "}" }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["(", ")"],
    ["[", "]"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*@(if|for|switch|match|raw|block|define|component|render|fill|watch|effect|reactive|stream|defer|lazy)\\b.*\\{\\s*$",
      "end": "^\\s*}\\s*$"
    }
  },
  "wordPattern": "(@[A-Za-z_][A-Za-z0-9_]*|[A-Za-z_][A-Za-z0-9_.-]*)"
}
